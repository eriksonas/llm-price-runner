# Copy to .env and fill in real values. .env is gitignored.

# Artificial Analysis Intelligence Index API key (free tier: 1000 req/day).
# Sign up: https://artificialanalysis.ai → Insights Platform → API keys.
# Required for live AA refresh — without it the app falls back to the
# seeded `aa_index` values in app/data/providers.py.
AA_API_KEY=

# Shared secret for the mutating endpoints (POST /api/update and
# POST /api/refresh) — clients send it as the X-Admin-Token header:
#   curl -X POST -H "X-Admin-Token: $ADMIN_TOKEN" .../api/refresh
# Generate with e.g.: openssl rand -hex 32
# Leave blank to disable those endpoints entirely (GET endpoints and the
# 6-hourly scheduled refresh are unaffected).
ADMIN_TOKEN=

# RIPE Atlas measurement-create API key, only needed if you run
# tools/run_probes.py to refresh app/data/rtt_measured.json.
# Sign up: https://atlas.ripe.net/ → My Atlas → API keys.
RIPE_ATLAS_KEY=
